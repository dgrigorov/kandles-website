---
import '../styles/tokens.css'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link
      rel="preload"
      as="font"
      href="/fonts/cormorant-garamond-bg.woff2"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <slot />
  </body>
</html>
